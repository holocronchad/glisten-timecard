# ── Glisten Timecard environment ──────────────────────────────────────
# Copy to .env and fill. Production values live on the DO droplet's .env.

# Server
PORT=3001
NODE_ENV=development

# Database — same DO Postgres as Holocron, isolated by `timeclock` schema.
# Production reuses Holocron's DATABASE_URL but appends ?options=-csearch_path=timeclock
DATABASE_URL=postgres://holocron:password@localhost:5432/holocron
DB_SCHEMA=timeclock

# Auth
# Manager JWT — separate secret from Holocron, NEVER reuse.
JWT_SECRET=change-me-to-a-64-char-random-string
JWT_TTL_HOURS=8

# Kiosk session token (very short — re-auth via PIN every action)
KIOSK_TOKEN_TTL_SECONDS=60

# PIN throttling
PIN_LOCKOUT_AFTER_FAILS=5
PIN_LOCKOUT_DURATION_MINUTES=5

# Auto-close cron (AZ time, Mon-Sun every day)
# Default: 23:59 AZ = 06:59 UTC next day
AUTO_CLOSE_CRON=59 6 * * *
AUTO_CLOSE_DEFAULT_SHIFT_HOURS=8

# Pay period (bi-weekly, anchor on a known Monday)
PAY_PERIOD_ANCHOR=2026-01-05
PAY_PERIOD_LENGTH_DAYS=14

# Overtime
OVERTIME_WEEKLY_HOURS=40

# Display timezone — all "today" boundaries and pay-period math use this.
TZ_DISPLAY=America/Phoenix

# Seed defaults — used by `npm run seed` to provision owner accounts.
# These are bcrypted and stored in users.password_hash.
SEED_ANAS_EMAIL=anas@glistendental.com
SEED_ANAS_PASSWORD=change-me-before-prod
SEED_DAWOOD_EMAIL=dawood@glistendental.com
SEED_DAWOOD_PASSWORD=change-me-before-prod
